x13_check <- function(){
# Use: call once at the top of a session to confirm X-13 is available.
# Note: x13binary installs/locates a compatible Census X-13 executable for your platform.
ok <- x13binary::checkX13binary()
if(!isTRUE(ok)) stop("X-13 binary not available. Try reinstalling x13binary or check permissions.")
invisible(ok)
}

read_parms_csv <- function(path){
# Use: reads your parms.txt (comma-delimited) into a keyed table.
# Expected columns in order: sid, log, model, outs, outs2 (same as your SAS infile statement).
# Note: in this minimal port we only use `log` to decide transform; model/outs/outs2 are kept for later.
p <- fread(path, header=FALSE, sep=",", col.names=c("sid","log","model","outs","outs2"))
p[, sid := trimws(sid)]
p[, log := toupper(trimws(log))]
setkey(p, sid)
p
}

filter_run_window <- function(d, byr, eyr, eqtr){
# Use: mimics your SAS windowing before adjustment.
# Keeps: year >= byr; drops observations after (eyr, eqtr).
d <- copy(as.data.table(d))
d[, `:=`(year=as.integer(year), q=as.integer(q))]
d <- d[year >= byr]
d <- d[!(year == eyr & q > eqtr)]
setorder(d, year, q)
d
}

extract_one_sid <- function(dat, sid){
# Use: returns only the rows for a single SID.
dt <- as.data.table(dat)
dt[sid == ..sid]
}

validate_quarterly_contiguous <- function(d){
# Use: sanity check to reduce silent misalignment.
# Requirement: one observation per quarter, no gaps, ordered.
# If you have gaps, you should fill missing quarters before building ts().
d <- copy(as.data.table(d))
setorder(d, year, q)
if(anyDuplicated(d[, .(year,q)])>0) stop("Duplicate year/q rows found for this SID.")
t0 <- d$year[1]*4 + d$q[1]
t1 <- d$year[nrow(d)]*4 + d$q[nrow(d)]
expected <- (t1 - t0 + 1)
if(expected != nrow(d)) stop("Missing quarter(s) detected. Fill gaps before seasonal adjustment.")
invisible(TRUE)
}

to_ts_quarterly <- function(d){
# Use: converts BED-style (year,q,n) into an R ts object with frequency=4.
# Requirement: data must be ordered and contiguous by quarter.
d <- as.data.table(d)
validate_quarterly_contiguous(d)
ts(d$n, start=c(d$year[1], d$q[1]), frequency=4)
}

compute_sf_sa <- function(x, sa){
# Use: matches your SAS “factor form” output.
# sf = n/sa is consistent with multiplicative seasonal factors and matches your SAS override for non-log.
sf <- as.numeric(x) / as.numeric(sa)
list(sf=sf, sa=as.numeric(sa))
}

run_x13_seasonal <- function(x, log_mode=FALSE, seats_save_s10s11=FALSE){
# Use: runs X-13ARIMA-SEATS via seasonal::seas() on a ts series.
# log_mode=TRUE mirrors transform{function=log} in your SAS spec.
# seats_save_s10s11=TRUE requests SEATS tables s10/s11 from X-13 (useful if you want to inspect raw tables).
tf <- if(log_mode) "log" else "none"
m <- if(seats_save_s10s11){
seas(x, transform.function=tf, seats=c("", "save=(s10 s11)"), regression.aictest="td")
} else {
seas(x, transform.function=tf, seats="", regression.aictest="td")
}
sa <- final(m)
list(model=m, sa=sa)
}

assemble_result <- function(d, sf, sa){
# Use: binds sf/sa back to the original year/q index for this SID.
# This avoids reconstructing year/q from ts timing and keeps exact alignment with input rows.
data.table(sid=d$sid[1], year=d$year, q=d$q, sf=round(sf,6), sa=round(sa,6))
}

apply_output_window <- function(res, eyr, eqtr){
# Use: replicates your SAS output trimming.
# If eqtr>=2: keep end quarter (and later if present).
# If eqtr==1: keep last 5 years, excluding first quarter of eyr-5.
r <- copy(as.data.table(res))
if(eqtr >= 2){
r <- r[(year > eyr) | (year == eyr & q >= eqtr)]
} else {
r <- r[year >= (eyr - 5)]
r <- r[!(year == (eyr - 5) & q == 1)]
}
r
}

fit_one_sid <- function(dat, parms, sid, byr, eyr, eqtr, seats_save_s10s11=FALSE){
# Use: end-to-end for one SID (closest to your SAS %data(sid) macro).
# Steps:
# 1) subset SID
# 2) apply run window filters
# 3) build ts
# 4) decide log vs none from parms
# 5) run X-13
# 6) compute sf/sa and return trimmed output
d0 <- extract_one_sid(dat, sid)
if(nrow(d0)==0) return(NULL)
d <- filter_run_window(d0, byr, eyr, eqtr)
if(nrow(d) < 8) return(NULL)
log_mode <- parms[J(sid), log][1] == "LOG"
x <- to_ts_quarterly(d)
fit <- run_x13_seasonal(x, log_mode=log_mode, seats_save_s10s11=seats_save_s10s11)
pair <- compute_sf_sa(x, fit$sa)
res <- assemble_result(d, pair$sf, pair$sa)
apply_output_window(res, eyr, eqtr)
}

fit_all_sids <- function(dat, parms_path, byr, eyr, eqtr, seats_save_s10s11=FALSE){
# Use: batch runner (closest to your SAS driver %sid + proc append base=all).
# Returns one big data.table: sid, year, q, sf, sa.
x13_check()
parms <- read_parms_csv(parms_path)
dt <- as.data.table(dat)
stopifnot(all(c("sid","year","q","n") %in% names(dt)))
sids <- unique(dt$sid)
out <- vector("list", length(sids))
for(i in seq_along(sids)){
sid <- sids[i]
out[[i]] <- fit_one_sid(dt, parms, sid, byr, eyr, eqtr, seats_save_s10s11=seats_save_s10s11)
}
rbindlist(out, use.names=TRUE, fill=TRUE)
}

