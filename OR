
conn = psycopg2.connect(**AWS_CONFIG)

q1 = """
select
    c.table_schema,
    c.table_name,
    c.column_name,
    c.data_type,
    s.null_frac,
    cls.reltuples::bigint as sample_size,
    round((s.null_frac * cls.reltuples)::numeric, 0)::bigint as num_nulls
from information_schema.columns c
join pg_class cls
    on cls.relname = c.table_name
join pg_namespace n
    on n.oid = cls.relnamespace
    and n.nspname = c.table_schema
left join pg_stats s
    on s.schemaname = c.table_schema
    and s.tablename = c.table_name
    and s.attname = c.column_name
where c.table_schema = 'wagerecusr'
"""

column_info = pd.read_sql(q1, con=conn)

column_info[['column_name','num_nulls']]

