import pandas as pd
import paramiko
from io import BytesIO

def read_sftp_sas(host, username, password, remote_path, port=22, encoding="latin1"):
    file_format = "xport" if remote_path.lower().endswith(".xpt") else "sas7bdat"
    transport = paramiko.Transport((host, port))
    transport.connect(username=username,password=password)
    sftp = paramiko.SFTPClient.from_transport(transport)
    try:
        with sftp.open(remote_path,"rb") as f:
            sas_bytes = BytesIO(f.read())
        return pd.read_sas(sas_bytes,format=file_format,encoding=encoding)
    finally:
        sftp.close()
        transport.close()


reader, remote_file, sftp, transport = read_sftp_sas(
    host="server.company.gov",
    username="my_username",
    password="my_password",
    remote_path="/data/folder/my_file.sas7bdat",
    lazy=True,
    chunksize=100_000
)

total_rows = 0
count_lte_7000 = 0
count_zero = 0

try:
    for chunk in reader:
        total_rows += len(chunk)
        count_lte_7000 += (chunk["wage"] <= 7000).sum()
        count_zero += (chunk["wage"] == 0).sum()
finally:
    remote_file.close()
    sftp.close()
    transport.close()

print(total_rows)
print(count_lte_7000)
print(count_zero)
