def summarize_all_class_transitions(tracked):
    rank_map = {
        "bottom 25%": 1,
        "25-50%": 2,
        "50-75%": 3,
        "top 25%": 4
    }

    class_summary = (
        tracked.groupby(
            ["yr_qtr", "original_class", "current_class", "class_transition"],
            dropna=False
        )
        .size()
        .reset_index(name="count")
        .sort_values(["yr_qtr", "original_class", "current_class"])
        .reset_index(drop=True)
    )

    state_within_class = (
        tracked.groupby(
            ["yr_qtr", "class_transition", "original_state", "state"],
            dropna=False
        )
        .size()
        .reset_index(name="count")
        .sort_values(["yr_qtr", "class_transition", "count"], ascending=[True, True, False])
        .reset_index(drop=True)
    )

    sector_within_class = (
        tracked.groupby(
            ["yr_qtr", "class_transition", "original_sector", "sector"],
            dropna=False
        )
        .size()
        .reset_index(name="count")
        .sort_values(["yr_qtr", "class_transition", "count"], ascending=[True, True, False])
        .reset_index(drop=True)
    )

    industry_within_class = (
        tracked.groupby(
            ["yr_qtr", "class_transition", "original_industry", "industry"],
            dropna=False
        )
        .size()
        .reset_index(name="count")
        .sort_values(["yr_qtr", "class_transition", "count"], ascending=[True, True, False])
        .reset_index(drop=True)
    )

    df = tracked.copy()
    df["orig_rank"] = df["original_class"].map(rank_map)
    df["curr_rank"] = df["current_class"].map(rank_map)
    df["movement"] = "same"
    df.loc[df["curr_rank"] > df["orig_rank"], "movement"] = "up"
    df.loc[df["curr_rank"] < df["orig_rank"], "movement"] = "down"

    movement_summary = (
        df.groupby(["yr_qtr", "movement"], dropna=False)
        .size()
        .reset_index(name="count")
        .sort_values(["yr_qtr", "movement"])
        .reset_index(drop=True)
    )

    movement_state = (
        df.groupby(["yr_qtr", "movement", "original_state", "state"], dropna=False)
        .size()
        .reset_index(name="count")
        .sort_values(["yr_qtr", "movement", "count"], ascending=[True, True, False])
        .reset_index(drop=True)
    )

    movement_sector = (
        df.groupby(["yr_qtr", "movement", "original_sector", "sector"], dropna=False)
        .size()
        .reset_index(name="count")
        .sort_values(["yr_qtr", "movement", "count"], ascending=[True, True, False])
        .reset_index(drop=True)
    )

    movement_industry = (
        df.groupby(["yr_qtr", "movement", "original_industry", "industry"], dropna=False)
        .size()
        .reset_index(name="count")
        .sort_values(["yr_qtr", "movement", "count"], ascending=[True, True, False])
        .reset_index(drop=True)
    )

    return {
        "class_summary": class_summary,
        "state_within_class": state_within_class,
        "sector_within_class": sector_within_class,
        "industry_within_class": industry_within_class,
        "movement_summary": movement_summary,
        "movement_state": movement_state,
        "movement_sector": movement_sector,
        "movement_industry": movement_industry
    }

summaries = summarize_all_class_transitions(tracked)

class_summary = summaries["class_summary"]
state_within_class = summaries["state_within_class"]
sector_within_class = summaries["sector_within_class"]
industry_within_class = summaries["industry_within_class"]
movement_summary = summaries["movement_summary"]
movement_state = summaries["movement_state"]
movement_sector = summaries["movement_sector"]
movement_industry = summaries["movement_industry"]

print(class_summary.head())
print(state_within_class.head())
print(sector_within_class.head())
print(industry_within_class.head())
print(movement_summary.head())
print(movement_state.head())
print(movement_sector.head())
print(movement_industry.head())
