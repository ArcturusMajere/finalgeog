import pandas as pd
import oracledb

def query_ui_list(conn,ui_list,table_name="wagerecusr.wage_data"):
    if not ui_list:
        raise ValueError("ui_list cannot be empty")

    binds={f"ui{i}":v for i,v in enumerate(ui_list)}
    placeholders=",".join(f":ui{i}" for i in range(len(ui_list)))

    sql=f"""
        SELECT
            COUNT(*) AS row_count,
            COUNT(DISTINCT id) AS id_count,
            AVG(wage) AS mean_wage
        FROM {table_name}
        WHERE ui IN ({placeholders})
    """

    return pd.read_sql(sql,conn,params=binds)



