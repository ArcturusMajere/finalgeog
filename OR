
import pandas as pd
import polars as pl
import oracledb



connection = oracledb.connect(**Creds)

q1 = f'''
    select * from ALL_TAB_COLUMNS 
      where OWNER = 'WAGERECUSR'
'''
column_info = pd.read_sql(q1, con=connection)
column_info[['COLUMN_NAME', 'NUM_NULLS']]
kdict = dict(zip(column_info['COLUMN_NAME'], column_info['DATA_TYPE']))
totobs  = column_info.query('COLUMN_NAME == "BLS_ID"')['SAMPLE_SIZE'].values[0]
totobs2  = column_info.query('COLUMN_NAME == "JOBTITLE"')['NUM_NULLS'].values[0]
assert totobs == totobs2
kcols = column_info.query('NUM_NULLS < @totobs')['COLUMN_NAME'].unique().tolist()
vardict = {'VARCHAR2' : " NOT IN ('0', '00000')", 'NUMBER' : ' > 0'}
kcolq = ', \n'.join(kcols)
idcols = ['YR', 'QTR', 'STATE_CODE',]
kcols2 = [c for c in kcols if c not in idcols]
countquery = [f'SUM(CASE WHEN {c} IS NOT NULL AND {c} {vardict[kdict[c]]} THEN 1 ELSE 0 END) AS count_{c}' for c in kcols2]
countq = ', \n'.join(countquery)


from datetime import datetime

minyr = datetime.now().year - column_info.query('COLUMN_NAME == "YR"')['NUM_DISTINCT'].values[0]
maxyr = datetime.now().year

sampsize = 10000

tresults = []
for yr in range(minyr, maxyr+1):
  for qtr in range(1,5):
    q1 = f'''
    
     with base_query as   (
        SELECT
            {kcolq},
            ROW_NUMBER() OVER (PARTITION BY YR, QTR, STATE_CODE
                                    ORDER BY YR
                                  ) AS row_num
        from wagerecusr.wage_data
        where YR = {yr}
            AND QTR = {qtr}
            AND WAGE > 0 
        ) 
    SELECT
        STATE_CODE,
        {countq}
    FROM base_query
    WHERE
        row_num <= {sampsize}
    GROUP BY
        STATE_CODE
      '''
    dft = pd.read_sql(q1, con=connection)
    dft['YR'] = yr
    dft['QTR'] = qtr
    tresults.append(dft)


dft = pd.concat(tresults)


for c in dft.columns:
  if c.startswith('COUNT'):
    dft[f'proportion_valid_{c.replace("COUNT_", "")}'] = dft[c] / sampsize
    dft.drop(columns = c,inplace=True)



dft.to_csv(f'{dloc}wr_info.csv')
dft.to_parquet(f'{dloc}wr_info.parquet')
