# sort IDs by wage and highest chosen
def dupeID(M):
    B = M.sort_values(by=['BLS_ID','WAGE'], ascending=[True,False])
    B = B.drop_duplicates(subset=['BLS_ID'],keep='first')
    return(B)

# extracts raw wage records per fips,yr,qtr
def fetch_wage(fips,yr,qtr):
    conn = oracledb.connect(user=open('USER.txt').read(),password=open('password.txt').read(),dsn="cfdbprd05.psb.bls.gov/wgrecprd.psb.bls.gov")
    sql = "SELECT t.BLS_ID,t.UI,t.RUN,t.WAGE,t.YR,t.QTR,t.state_code FROM wagerecusr.wage_data t WHERE t.YR=:yr AND t.QTR=:qtr AND t.state_code=:fips AND WAGE > 0"
    p={"yr":yr,"qtr":qtr,"fips":fips}
    with conn.cursor() as c:c.execute(sql,p); r=c.fetchall(); cols=[x[0] for x in c.description]
    return pd.DataFrame(r,columns=cols)

