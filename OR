import pandas as pd

def aggregate_by_quarter_id_categories(df):
    cats=[f"category_{i}" for i in range(1,7)]
    id_df=(
        df.groupby(
            ["yr_qtr","ID"]+cats,
            as_index=False,
            dropna=False
        )
        .agg(
            wage_sum=("wage","sum"),
            hour_sum=("hours","sum")
        )
        .sort_values(["yr_qtr","ID"]+cats)
        .reset_index(drop=True)
    )
    return id_df

