import pandas as pd
import numpy as np

def summarize_grp_cat_bins(df):
    out = df.copy()

    yq = out["yr_qtr"].astype(str).str.split("-", expand=True)
    out["year"] = pd.to_numeric(yq[0], errors="coerce")
    out["qtr"] = pd.to_numeric(yq[1], errors="coerce")

    out["period"] = np.select(
        [
            ((out["year"] == 2015) & (out["qtr"] >= 1)) | ((out["year"] > 2015) & (out["year"] < 2020)),
            ((out["year"] == 2020) & (out["qtr"] >= 1)) | ((out["year"] > 2020) & (out["year"] < 2024)) | ((out["year"] == 2024) & (out["qtr"] <= 2)),
            ((out["year"] == 2024) & (out["qtr"] >= 3)) | ((out["year"] == 2025) & (out["qtr"] <= 3))
        ],
        ["pre", "term", "post"],
        default=np.nan
    )

    out = out[out["period"].notna()].copy()

    result = (
        out.groupby(["grp", "CAT", "period"], as_index=False)
        .agg(
            mean_wage=("WAGE", "mean"),
            median_wage=("WAGE", "median"),
            median_hours=("HOURS", "median"),
            n_ids=("ID", "nunique"),
            n_rows=("ID", "size")
        )
    )

    result["period"] = pd.Categorical(result["period"], categories=["pre", "term", "post"], ordered=True)
    result = result.sort_values(["grp", "CAT", "period"]).reset_index(drop=True)

    return result

