
import pandas as pd
import numpy as np
import webbrowser
import tempfile
import os


def compare_dataframes(
    df1: pd.DataFrame,
    df2: pd.DataFrame,
    tol: float = None,
    show_heatmap: bool = True,
    df1_name: str = "DataFrame 1",
    df2_name: str = "DataFrame 2",
) -> dict:
    """
    Compare two DataFrames and return a disagreement report,
    with an optional colorful interactive HTML heatmap.

    Parameters
    ----------
    df1, df2     : pd.DataFrame
    tol          : float, optional — numeric tolerance (e.g. 0.01). If None, exact match.
    show_heatmap : bool — open heatmap in browser (default True)
    df1_name     : str — label for df1 in the heatmap
    df2_name     : str — label for df2 in the heatmap

    Returns
    -------
    dict with keys:
        shape_match   : bool
        common_cols   : list
        only_in_df1   : list  (columns)
        only_in_df2   : list
        disagreement  : pd.DataFrame  (bool mask, True = mismatch)
        diff_df       : pd.DataFrame  (details for mismatched cells)
        summary       : pd.Series     (mismatch count per column)
        mismatch_rate : float         (0.0 – 1.0)
        heatmap_path  : str | None    (path to saved HTML file)
    """
    common_cols = list(df1.columns.intersection(df2.columns))
    only_in_df1 = list(df1.columns.difference(df2.columns))
    only_in_df2 = list(df2.columns.difference(df1.columns))

    n_rows = min(len(df1), len(df2))
    row_diff = abs(len(df1) - len(df2))

    a = df1[common_cols].iloc[:n_rows].reset_index(drop=True)
    b = df2[common_cols].iloc[:n_rows].reset_index(drop=True)

    # ── Build disagreement mask ──────────────────────────────────────────────
    if tol is not None:
        num_cols = a.select_dtypes(include=np.number).columns
        mask = a.ne(b)
        for col in num_cols:
            mask[col] = (a[col] - b[col]).abs() > tol
    else:
        mask = a.ne(b)

    # ── Long-form diff ───────────────────────────────────────────────────────
    rows = [
        {"row": r, "col": c, "df1": a.at[r, c], "df2": b.at[r, c]}
        for r in range(n_rows)
        for c in common_cols
        if mask.at[r, c]
    ]
    diff_df = pd.DataFrame(rows, columns=["row", "col", "df1", "df2"])

    total_cells = mask.size
    mismatch_count = int(mask.values.sum())
    mismatch_rate = mismatch_count / total_cells if total_cells else 0.0

    # ── Build heatmap ────────────────────────────────────────────────────────
    heatmap_path = None
    if show_heatmap:
        heatmap_path = _build_heatmap(
            a, b, mask, diff_df,
            df1_name, df2_name,
            mismatch_count, total_cells, mismatch_rate,
            row_diff, only_in_df1, only_in_df2,
            tol,
        )
        webbrowser.open(f"file://{heatmap_path}")

    return {
        "shape_match":   df1.shape == df2.shape,
        "common_cols":   common_cols,
        "only_in_df1":   only_in_df1,
        "only_in_df2":   only_in_df2,
        "disagreement":  mask,
        "diff_df":       diff_df,
        "summary":       mask.sum().rename("mismatches"),
        "mismatch_rate": mismatch_rate,
        "heatmap_path":  heatmap_path,
    }


# ── HTML heatmap builder ─────────────────────────────────────────────────────

def _build_heatmap(
    a, b, mask, diff_df,
    df1_name, df2_name,
    mismatch_count, total_cells, mismatch_rate,
    row_diff, only_in_df1, only_in_df2,
    tol,
):
    cols = list(a.columns)
    n_rows = len(a)

    # Per-column mismatch rate → drives column header heat
    col_rates = {c: mask[c].mean() for c in cols}

    def cell_style(match, v1, v2):
        if match:
            return "match"
        try:
            diff = abs(float(v1) - float(v2))
            if diff < 1:
                return "mismatch-low"
            elif diff < 10:
                return "mismatch-mid"
            else:
                return "mismatch-high"
        except (ValueError, TypeError):
            return "mismatch-high"

    def col_heat_class(rate):
        if rate == 0:
            return "col-cool"
        elif rate < 0.25:
            return "col-warm-low"
        elif rate < 0.6:
            return "col-warm-mid"
        else:
            return "col-warm-high"

    # Build table rows
    table_rows = []
    for r in range(n_rows):
        cells = [f'<td class="row-idx">{r}</td>']
        for c in cols:
            v1 = a.at[r, c]
            v2 = b.at[r, c]
            m = mask.at[r, c]
            cls = cell_style(m, v1, v2)
            if m:
                inner = (
                    f'<span class="v1">{v1}</span>'
                    f'<span class="v2">{v2}</span>'
                )
                title = f'df1: {v1} | df2: {v2}'
                cells.append(f'<td class="{cls}" title="{title}">{inner}</td>')
            else:
                cells.append(f'<td class="{cls}">{v1}</td>')
        table_rows.append("<tr>" + "".join(cells) + "</tr>")

    # Column headers
    col_headers = ['<th class="row-idx">#</th>']
    for c in cols:
        rate_pct = f"{col_rates[c]*100:.0f}%"
        col_headers.append(
            f'<th class="{col_heat_class(col_rates[c])}" title="{rate_pct} mismatch">'
            f'{c}<span class="col-rate">{rate_pct}</span></th>'
        )

    # Warnings
    warnings = []
    if row_diff:
        warnings.append(f"⚠ Row count differs by {row_diff} — only first {len(a)} rows compared")
    if only_in_df1:
        warnings.append(f"⚠ Columns only in {df1_name}: {', '.join(only_in_df1)}")
    if only_in_df2:
        warnings.append(f"⚠ Columns only in {df2_name}: {', '.join(only_in_df2)}")
    if tol is not None:
        warnings.append(f"ℹ Numeric tolerance: ±{tol}")
    warnings_html = "".join(f'<div class="warn">{w}</div>' for w in warnings)

    match_count = total_cells - mismatch_count
    pct = f"{mismatch_rate*100:.1f}"

    html = f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>DataFrame Comparison</title>
<style>
