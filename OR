"""Build split-grain dominant NAICS parquet outputs from LDB SAS quarters.

# Dataflow:
# 1) parse_args()
# 2) cache_normalized_ldb()
# 3) process_state()
# 4) validate_outputs()
# 5) save_artifacts()

# Call graph:
# main -> parse_args -> run
# run -> cache_normalized_ldb -> OpenLDB -> normalize_ldb -> state parquet cache
# run -> process_state -> build_naics_run / build_dominant_naics_ui
# process_state -> deduplicate_naics_run -> assert_unique_keys -> save state parquet files
"""

from __future__ import annotations

import argparse
import gc
import hashlib
import json
import shutil
import subprocess
import sys
import time
from collections import defaultdict
from dataclasses import asdict, dataclass
from pathlib import Path
from typing import Iterable, Optional, Sequence

import pandas as pd
import polars as pl


NAICS_LEVELS: tuple[int, ...] = (2, 3, 4, 5, 6)
SOURCE_COLUMNS: dict[str, str] = {
    "UI_ACCT": "ui_acct",
    "RPT_UNIT": "run",
    "STATE_FIPS": "fips",
    "MEEI": "meei",
    "TOT_WAGE": "wages",
    "NAICS": "naics_code",
    "M1_EMPL": "M1_EMPL",
    "M2_EMPL": "M2_EMPL",
    "M3_EMPL": "M3_EMPL",
}
EMPLOYMENT_COLUMNS: tuple[str, ...] = ("M1_EMPL", "M2_EMPL", "M3_EMPL")
UI_KEY: tuple[str, ...] = ("fips", "ui_acct", "year", "qtr")
RUN_KEY: tuple[str, ...] = ("fips", "ui_acct", "run", "year", "qtr")
NAICS_COLUMNS: tuple[str, ...] = tuple(f"naics{level}" for level in NAICS_LEVELS)
PROP_COLUMNS: tuple[str, ...] = tuple(
    f"prop_emp_dom_naics{level}" for level in NAICS_LEVELS
)
UI_OUTPUT_COLUMNS: tuple[str, ...] = UI_KEY + PROP_COLUMNS + NAICS_COLUMNS + ("Dmulti",)
RUN_OUTPUT_COLUMNS: tuple[str, ...] = RUN_KEY + PROP_COLUMNS + NAICS_COLUMNS + ("Dmulti",)
PRODUCT_PREFIXES: dict[str, str] = {
    "dominant_naics_ui": "dominant_naics_ui",
    "naics_run": "naics_run",
}
NUMERIC_DTYPES = {
    pl.Int8,
    pl.Int16,
    pl.Int32,
    pl.Int64,
    pl.UInt8,
    pl.UInt16,
    pl.UInt32,
    pl.UInt64,
    pl.Float32,
    pl.Float64,
}
DEFAULT_LDB_ROOT = Path("/ldbsas/ldb")
DEFAULT_OUTPUT_ROOT = Path("/wagerec/current_dominantnaics_v4/parquet")
DEFAULT_TMP_ROOT = Path("/tmp/domnaics_v4")
OUTPUT_LAYOUT = "hive_partitioned_by_year_qtr_fips"


@dataclass(frozen=True)
class RunConfig:
    """Runtime settings for one LDB year-quarter build."""

    year: int
    quarter: int
    output_root: Path
    tmp_root: Path
    fips: Optional[tuple[int, ...]]
    keep_cache: bool
    run_tag: str
    issue_log_path: Optional[Path] = None

    @property
    def source_path(self) -> Path:
        return DEFAULT_LDB_ROOT / f"estab_dynamic{self.year}{self.quarter}.sas7bdat"

    @property
    def cache_dir(self) -> Path:
        return self.tmp_root / self.run_tag / "normalized_ldb"


def parse_args(argv: Optional[Sequence[str]] = None) -> RunConfig:
    """Parse CLI arguments into an explicit run config."""

    parser = argparse.ArgumentParser(
        description="Create split-grain dominant NAICS parquet outputs."
    )
    parser.add_argument("--year", type=int, required=True)
    parser.add_argument("--quarter", type=int, choices=(1, 2, 3, 4), required=True)
    parser.add_argument(
        "--output-root",
        type=Path,
        default=DEFAULT_OUTPUT_ROOT,
    )
    parser.add_argument("--tmp-root", type=Path, default=DEFAULT_TMP_ROOT)
    parser.add_argument(
        "--fips",
        default=None,
        help="Optional comma-separated FIPS list. Default is all FIPS in the LDB quarter.",
    )
    parser.add_argument(
        "--keep-cache",
        action="store_true",
        help="Keep normalized temporary parquet files under --tmp-root.",
    )
    parser.add_argument(
        "--issue-log-path",
        type=Path,
        default=None,
        help="Optional JSONL quality log path for duplicate keys and other review items.",
    )
    parsed = parser.parse_args(argv)
    run_tag = f"yr{parsed.year}_q{parsed.quarter}_{time.strftime('%Y%m%d_%H%M%S')}"
    return RunConfig(
        year=parsed.year,
        quarter=parsed.quarter,
        output_root=parsed.output_root,
        tmp_root=parsed.tmp_root,
        fips=parse_fips_list(parsed.fips),
        keep_cache=parsed.keep_cache,
        run_tag=run_tag,
        issue_log_path=parsed.issue_log_path,
    )


def parse_fips_list(raw_fips: Optional[str]) -> Optional[tuple[int, ...]]:
    """Convert a comma-separated FIPS option to sorted integer codes."""

    if raw_fips is None or raw_fips.strip().lower() in {"", "all"}:
        return None
    fips = tuple(sorted({int(item.strip()) for item in raw_fips.split(",") if item.strip()}))
    if not fips:
        raise ValueError("--fips was provided but no FIPS codes were parsed")
    return fips


def OpenLDB(source_path: Path) -> pl.LazyFrame:
    """Read one complete raw LDB source quarter as a Polars LazyFrame.

    Replacement contract: return a complete Polars LazyFrame with the raw LDB
    columns listed in SOURCE_COLUMNS. Downstream normalization handles
    case-insensitive source names, filtering, and recodes.
    """

    if not source_path.exists():
        raise FileNotFoundError(f"LDB SAS source not found: {source_path}")

    raw_ldb = pd.read_sas(
        source_path,
        format="sas7bdat",
        encoding="utf-8",
    )
    return pl.from_pandas(raw_ldb).lazy()


def normalize_ldb(
    raw_ldb: pl.LazyFrame,
    year: int,
    quarter: int,
    fips_filter: Optional[Iterable[int]] = None,
) -> pl.LazyFrame:
    """Normalize raw LDB rows to the columns used downstream.

    Inputs are raw LDB column names. Output is a Polars LazyFrame at establishment
    grain after MEEI==9 removal. Assumes RUN is required for v4.
    """

    source_columns = raw_ldb.collect_schema().names()
    source_by_upper = {str(column).upper(): column for column in source_columns}
    missing = [column for column in SOURCE_COLUMNS if column not in source_by_upper]
    if missing:
        raise ValueError(f"Missing required LDB source columns: {missing}")

    ldb = raw_ldb.select(
        [pl.col(source_by_upper[src]).alias(dst) for src, dst in SOURCE_COLUMNS.items()]
    )
    ldb_schema = ldb.collect_schema()
    ldb = ldb.select(
        _identifier_expr(ldb_schema, "ui_acct").alias("ui_acct"),
        _identifier_expr(ldb_schema, "run").alias("run"),
        pl.col("fips").cast(pl.Int32, strict=False).alias("fips"),
        pl.col("meei").cast(pl.Int16, strict=False).alias("meei"),
        pl.col("wages").cast(pl.Float64, strict=False).alias("wages"),
        pl.col("naics_code").cast(pl.Int64, strict=False).cast(pl.Utf8).alias("naics_code"),
        *[
            pl.col(column).cast(pl.Float64, strict=False).alias(column)
            for column in EMPLOYMENT_COLUMNS
        ],
    )
    ldb = ldb.filter(pl.col("meei") != 9)
    if fips_filter is not None:
        ldb = ldb.filter(pl.col("fips").is_in(list(fips_filter)))
    ldb = ldb.with_columns(
        pl.mean_horizontal([pl.col(column) for column in EMPLOYMENT_COLUMNS]).alias("aaemp")
    )

    ui_acct_edited = edited_ui_acct_expr(year, quarter)
    ldb = ldb.with_columns(
        ui_acct_edited.alias("ui_acct_edited_value"),
        (ui_acct_edited != pl.col("ui_acct")).alias("ui_acct_edited"),
    ).with_columns(pl.col("ui_acct_edited_value").alias("ui_acct"))

    # Explicit NAICS2 recode: these official sectors span multiple 2-digit codes,
    # and v4 preserves the v3/current dominant-NAICS sector convention.
    ldb = ldb.with_columns(
        pl.lit(year, dtype=pl.Int32).alias("year"),
        pl.lit(quarter, dtype=pl.Int8).alias("qtr"),
        *[
            pl.col("naics_code").str.slice(0, level).alias(f"naics{level}")
            for level in NAICS_LEVELS
        ],
    ).with_columns(
        pl.when(pl.col("naics2").is_in(["31", "32", "33"]))
        .then(pl.lit("31-33"))
        .when(pl.col("naics2").is_in(["44", "45"]))
        .then(pl.lit("44-45"))
        .when(pl.col("naics2").is_in(["48", "49"]))
        .then(pl.lit("48-49"))
        .otherwise(pl.col("naics2"))
        .alias("naics2")
    )
    return ldb.select(
        "fips",
        "ui_acct",
        "run",
        "year",
        "qtr",
        "meei",
        "wages",
        "aaemp",
        *NAICS_COLUMNS,
        "ui_acct_edited",
    )


def _identifier_expr(schema: pl.Schema, column: str) -> pl.Expr:
    """Return an identifier expression preserving leading zeroes for string columns."""

    dtype = schema[column]
    if dtype in NUMERIC_DTYPES:
        return pl.col(column).cast(pl.Int64, strict=False).cast(pl.Utf8)
    return pl.col(column).cast(pl.Utf8).str.strip_chars()


def edited_ui_acct_expr(year: int, quarter: int) -> pl.Expr:
    """Apply UI edits needed to align LDB account format to wage-record keys."""

    ui_acct = pl.col("ui_acct")
    fl_edit = pl.concat_str([ui_acct.str.slice(-1, 1), ui_acct.str.slice(0, 9)])
    ct_or_ks_edit = pl.concat_str([ui_acct.str.slice(3), pl.lit("000")])
    expr = pl.when(
        (pl.col("fips") == 12) & (ui_acct.str.len_chars() == 10) & ui_acct.str.ends_with("0")
    ).then(fl_edit)
    if year < 2022 or (year == 2022 and quarter == 1):
        expr = expr.when(
            (pl.col("fips") == 9) & (ui_acct.str.len_chars() == 10) & ui_acct.str.starts_with("000")
        ).then(ct_or_ks_edit)
    return expr.when((pl.col("fips") == 20) & ui_acct.str.starts_with("000")).then(
        ct_or_ks_edit
    ).otherwise(ui_acct)


def assert_no_missing_values(df: pl.DataFrame, columns: Sequence[str]) -> None:
    """Fail fast when required columns contain null or blank string values."""

    missing_counts: dict[str, int] = {}
    for column in columns:
        expr = pl.col(column).is_null()
        if df.schema[column] == pl.Utf8:
            expr = expr | (pl.col(column).str.strip_chars().str.len_chars() == 0)
        count = df.filter(expr).height
        if count:
            missing_counts[column] = count
    if missing_counts:
        raise ValueError(f"Required values are missing: {missing_counts}")


def cache_normalized_ldb(config: RunConfig) -> tuple[list[int], dict[int, dict[str, int]]]:
    """Cache normalized LDB state parquet files under /tmp."""

    if config.cache_dir.exists():
        shutil.rmtree(config.cache_dir)
    config.cache_dir.mkdir(parents=True, exist_ok=True)

    stats: dict[int, dict[str, int]] = defaultdict(lambda: {"input_rows": 0, "edited_rows": 0})
    normalized = normalize_ldb(
        raw_ldb=OpenLDB(config.source_path),
        year=config.year,
        quarter=config.quarter,
        fips_filter=config.fips,
    ).collect()
    if normalized.is_empty():
        raise ValueError("No LDB rows remained after MEEI and FIPS filtering")

    assert_no_missing_values(
        normalized,
        ["fips", "ui_acct", "run", "meei", "wages", "aaemp", *NAICS_COLUMNS],
    )

    state_summaries = normalized.group_by("fips").agg(
        pl.len().alias("input_rows"),
        pl.col("ui_acct_edited").sum().cast(pl.Int64).alias("edited_rows"),
    )
    for row in state_summaries.iter_rows(named=True):
        fips = int(row["fips"])
        stats[fips]["input_rows"] += int(row["input_rows"])
        stats[fips]["edited_rows"] += int(row["edited_rows"])
        state_dir = config.cache_dir / f"fips_{fips:02d}"
        state_dir.mkdir(parents=True, exist_ok=True)
        normalized.filter(pl.col("fips") == fips).write_parquet(
            state_dir / "normalized_ldb.parquet"
        )
    print(
        f"cached rows={normalized.height} "
        f"states={normalized.select('fips').n_unique()}"
    )
    del normalized
    gc.collect()
    return sorted(stats), stats


def process_state(config: RunConfig, fips: int) -> dict[str, object]:
    """Build, validate, and save both split-grain outputs for one state."""

    state_dir = config.cache_dir / f"fips_{fips:02d}"
    state_df = pl.scan_parquet(str(state_dir / "*.parquet")).collect()
    if state_df.is_empty():
        raise ValueError(f"No normalized LDB rows found for fips={fips}")
    assert_no_missing_values(state_df, list(RUN_KEY) + list(NAICS_COLUMNS))

    run_df = build_naics_run(state_df)
    run_df, duplicate_summary = deduplicate_naics_run(run_df, config, fips)
    ui_df, ui_counts = build_dominant_naics_ui(state_df)
    assert_unique_keys(run_df, RUN_KEY, "naics_run")
    assert_unique_keys(ui_df, UI_KEY, "dominant_naics_ui")

    ui_path = product_partition_path(
        config.output_root, "dominant_naics_ui", config.year, config.quarter, fips
    )
    run_path = product_partition_path(
        config.output_root, "naics_run", config.year, config.quarter, fips
    )
    ui_path.parent.mkdir(parents=True, exist_ok=True)
    run_path.parent.mkdir(parents=True, exist_ok=True)
    ui_df.write_parquet(ui_path)
    run_df.write_parquet(run_path)
    summary = {
        "fips": fips,
        "input_rows": state_df.height,
        "run_rows": run_df.height,
        "ui_rows": ui_df.height,
        "single_ui_rows": ui_counts["single_ui_rows"],
        "multi_ui_rows": ui_counts["multi_ui_rows"],
        "naics_run_duplicate_groups": duplicate_summary["duplicate_groups"],
        "naics_run_duplicate_rows": duplicate_summary["duplicate_rows"],
        "naics_run_rows_dropped": duplicate_summary["rows_dropped"],
        "edited_rows": int(state_df["ui_acct_edited"].sum()),
        "dominant_naics_ui_path": str(ui_path),
        "naics_run_path": str(run_path),
        "quality_issue_log_path": str(quality_issue_log_path(config)),
    }
    print(
        "state_qc "
        f"fips={fips} input_rows={summary['input_rows']} "
        f"run_rows={summary['run_rows']} ui_rows={summary['ui_rows']} "
        f"single_ui_rows={summary['single_ui_rows']} "
        f"multi_ui_rows={summary['multi_ui_rows']} "
        f"naics_run_rows_dropped={summary['naics_run_rows_dropped']} "
        f"edited_rows={summary['edited_rows']}"
    )
    return summary


def product_partition_dir(
    output_root: Path,
    product: str,
    year: int,
    quarter: int,
    fips: int,
) -> Path:
    """Return the year/qtr/fips partition directory for one output product."""

    if product not in PRODUCT_PREFIXES:
        raise ValueError(f"Unknown product: {product}")
    return (
        output_root
        / product
        / f"year={year}"
        / f"qtr={quarter}"
        / f"fips={fips:02d}"
    )


def product_partition_path(
    output_root: Path,
    product: str,
    year: int,
    quarter: int,
    fips: int,
) -> Path:
    """Return the partitioned parquet path for one state-quarter product."""

    return product_partition_dir(output_root, product, year, quarter, fips) / (
        f"{PRODUCT_PREFIXES[product]}.parquet"
    )


def flat_product_path(
    output_root: Path,
    product: str,
    year: int,
    quarter: int,
    fips: int,
) -> Path:
    """Return the legacy flat parquet path for one state-quarter product."""

    if product not in PRODUCT_PREFIXES:
        raise ValueError(f"Unknown product: {product}")
    prefix = PRODUCT_PREFIXES[product]
    return output_root / product / f"{prefix}_yr{year}_q{quarter}_fips{fips:02d}.parquet"


def build_naics_run(state_df: pl.DataFrame) -> pl.DataFrame:
    """Create direct establishment/RUN-grain NAICS rows from normalized LDB data."""

    return state_df.with_columns(
        *[pl.lit(1.0, dtype=pl.Float64).alias(column) for column in PROP_COLUMNS],
        pl.col("meei").is_in([3, 4, 5, 6]).alias("Dmulti"),
    ).select(RUN_OUTPUT_COLUMNS)


def quality_issue_log_path(config: RunConfig) -> Path:
    """Return the JSONL quality log path for review items."""

    if config.issue_log_path is not None:
        return config.issue_log_path
    return (
        config.output_root
        / "manifests"
        / f"quality_issues_{config.run_tag}.jsonl"
    )


def deduplicate_naics_run(
    run_df: pl.DataFrame, config: RunConfig, fips: int
) -> tuple[pl.DataFrame, dict[str, int]]:
    """Log duplicate RUN-grain keys and keep the first row for each key."""

    duplicate_groups = (
        run_df.group_by(RUN_KEY)
        .agg(pl.len().alias("n"))
        .filter(pl.col("n") > 1)
        .sort(RUN_KEY)
    )
    if duplicate_groups.is_empty():
        return run_df, {"duplicate_groups": 0, "duplicate_rows": 0, "rows_dropped": 0}

    duplicate_rows = int(duplicate_groups["n"].sum())
    rows_dropped = duplicate_rows - duplicate_groups.height
    log_path = quality_issue_log_path(config)
    log_path.parent.mkdir(parents=True, exist_ok=True)
    with log_path.open("a", encoding="utf-8") as log_file:
        for row in duplicate_groups.iter_rows(named=True):
            duplicate_count = int(row["n"])
            payload = {
                "issue": "duplicate_naics_run_key",
                "year": int(row["year"]),
                "qtr": int(row["qtr"]),
                "state_fips": int(row["fips"]),
                "ui_acct": str(row["ui_acct"]),
                "run": str(row["run"]),
                "duplicate_rows": duplicate_count,
                "rows_dropped": duplicate_count - 1,
                "action": "kept_first_row",
            }
            log_file.write(json.dumps(payload, sort_keys=True) + "\n")

    print(
        "quality_issue issue=duplicate_naics_run_key "
        f"year={config.year} quarter={config.quarter} fips={fips} "
        f"duplicate_groups={duplicate_groups.height} duplicate_rows={duplicate_rows} "
        f"rows_dropped={rows_dropped} action=kept_first_row log={log_path}"
    )
    return run_df.unique(subset=RUN_KEY, keep="first", maintain_order=True), {
        "duplicate_groups": duplicate_groups.height,
        "duplicate_rows": duplicate_rows,
        "rows_dropped": rows_dropped,
    }


def build_dominant_naics_ui(state_df: pl.DataFrame) -> tuple[pl.DataFrame, dict[str, int]]:
    """Create UI-grain dominant NAICS rows with single-UI shortcut routing."""

    ui_totals = state_df.group_by(UI_KEY).agg(
        pl.len().alias("n_estabs"),
        pl.col("aaemp").sum().alias("aaemp_ui"),
        pl.col("meei").max().alias("meei"),
    )
    single_keys = ui_totals.filter(pl.col("n_estabs") == 1)
    multi_totals = ui_totals.filter(pl.col("n_estabs") > 1)

    outputs: list[pl.DataFrame] = []
    if not single_keys.is_empty():
        outputs.append(
            state_df.join(single_keys.select(UI_KEY + ("meei",)), on=UI_KEY, how="inner")
            .with_columns(
                *[pl.lit(1.0, dtype=pl.Float64).alias(column) for column in PROP_COLUMNS],
                pl.col("meei_right").is_in([3, 4, 5, 6]).alias("Dmulti"),
            )
            .select(UI_OUTPUT_COLUMNS)
        )
    if not multi_totals.is_empty():
        multi_base = state_df.join(multi_totals.select(UI_KEY), on=UI_KEY, how="inner")
        outputs.append(build_multi_ui_output(multi_base, multi_totals))

    ui_df = pl.concat(outputs, how="vertical").select(UI_OUTPUT_COLUMNS)
    return ui_df, {
        "single_ui_rows": single_keys.height,
        "multi_ui_rows": multi_totals.height,
    }


def build_multi_ui_output(multi_base: pl.DataFrame, multi_totals: pl.DataFrame) -> pl.DataFrame:
    """Aggregate multi-establishment UI keys and select dominant NAICS at each level."""

    output = multi_totals.select(
        *UI_KEY,
        "aaemp_ui",
        pl.col("meei").is_in([3, 4, 5, 6]).alias("Dmulti"),
    )
    for level in NAICS_LEVELS:
        output = output.join(dominant_for_level(multi_base, level), on=UI_KEY, how="left")

    output = output.with_columns(
        *[
            pl.when(pl.col(f"number_unique_naics{level}") == 1)
            .then(pl.lit(1.0))
            .when(pl.col("aaemp_ui") == 0)
            .then(pl.lit(0.0))
            .otherwise(pl.col(f"aaemp_naics{level}") / pl.col("aaemp_ui"))
            .alias(f"prop_emp_dom_naics{level}")
            for level in NAICS_LEVELS
        ]
    )
    return output.select(UI_OUTPUT_COLUMNS)


def dominant_for_level(multi_base: pl.DataFrame, level: int) -> pl.DataFrame:
    """Select dominant NAICS for one level by employment, wages, then hash tie-break."""

    naics_column = f"naics{level}"
    grouped = multi_base.group_by(*UI_KEY, naics_column).agg(
        pl.col("aaemp").sum().alias(f"aaemp_naics{level}"),
        pl.col("wages").sum().alias("wages_sum"),
    )
    grouped = grouped.with_columns(
        pl.struct([*UI_KEY, naics_column]).hash(seed=17).alias("tie_hash")
    )
    number_unique = grouped.group_by(UI_KEY).agg(
        pl.len().alias(f"number_unique_naics{level}")
    )
    dominant = (
        grouped.sort([*UI_KEY, f"aaemp_naics{level}", "wages_sum", "tie_hash"])
        .unique(subset=UI_KEY, keep="last", maintain_order=True)
        .join(number_unique, on=UI_KEY, how="inner")
        .select(
            *UI_KEY,
            naics_column,
            f"aaemp_naics{level}",
            f"number_unique_naics{level}",
        )
    )
    return dominant


def assert_unique_keys(df: pl.DataFrame, keys: Sequence[str], label: str) -> None:
    """Fail if an output is not unique at its advertised grain."""

    duplicate_groups = df.group_by(keys).agg(pl.len().alias("n")).filter(pl.col("n") > 1)
    if not duplicate_groups.is_empty():
        duplicate_rows = int(duplicate_groups["n"].sum())
        raise ValueError(
            f"{label} is not unique on {list(keys)}; "
            f"duplicate_groups={duplicate_groups.height}; duplicate_rows={duplicate_rows}"
        )


def clear_existing_quarter_outputs(config: RunConfig, state_fips: Sequence[int]) -> None:
    """Remove stale v4 parquet files for the same output scope before writing."""

    for product, prefix in PRODUCT_PREFIXES.items():
        product_dir = config.output_root / product
        if not product_dir.exists():
            continue
        removed = 0
        if config.fips is None:
            paths = list(product_dir.glob(f"{prefix}_yr{config.year}_q{config.quarter}_fips*.parquet"))
            partition_dirs = list(
                (product_dir / f"year={config.year}" / f"qtr={config.quarter}").glob("fips=*")
            )
        else:
            paths = [
                flat_product_path(config.output_root, product, config.year, config.quarter, fips)
                for fips in state_fips
            ]
            partition_dirs = [
                product_partition_dir(config.output_root, product, config.year, config.quarter, fips)
                for fips in state_fips
            ]
        for path in paths:
            if path.exists():
                path.unlink()
                removed += 1
        for partition_dir in partition_dirs:
            if partition_dir.exists():
                shutil.rmtree(partition_dir)
                removed += 1
        if removed:
            print(f"removed_existing product={product} files={removed}")


def write_manifest(config: RunConfig, state_summaries: list[dict[str, object]]) -> Path:
    """Write disclosure-safe provenance and row-count metadata for the run."""

    repo_root = Path(__file__).resolve().parents[2]
    issue_log_path = quality_issue_log_path(config)
    try:
        git_commit = subprocess.check_output(
            ["git", "rev-parse", "HEAD"], cwd=repo_root, text=True
        ).strip()
    except Exception:
        git_commit = "unknown"

    signature_payload = {
        "year": config.year,
        "quarter": config.quarter,
        "source_path": str(config.source_path),
        "fips": list(config.fips) if config.fips is not None else "all",
        "naics_levels": list(NAICS_LEVELS),
        "output_layout": OUTPUT_LAYOUT,
        "ui_key": list(UI_KEY),
        "run_key": list(RUN_KEY),
        "ui_edits": "CT_through_2022q1_FL_KS_before_grouping",
        "duplicate_naics_run_action": "log_and_keep_first",
    }
    spec_signature = hashlib.sha256(
        json.dumps(signature_payload, sort_keys=True).encode("utf-8")
    ).hexdigest()

    manifest = {
        "script": str(Path(__file__).resolve()),
        "git_commit": git_commit,
        "command": " ".join(sys.argv),
        "parameters": {
            **asdict(config),
            "ldb_root": str(DEFAULT_LDB_ROOT),
            "output_root": str(config.output_root),
            "tmp_root": str(config.tmp_root),
            "source_path": str(config.source_path),
            "cache_dir": str(config.cache_dir),
            "issue_log_path": str(issue_log_path),
        },
        "spec_signature": spec_signature,
        "naics_levels": list(NAICS_LEVELS),
        "ui_key": list(UI_KEY),
        "run_key": list(RUN_KEY),
        "issue_log_path": str(issue_log_path),
        "state_summaries": state_summaries,
    }
    manifest_path = (
        config.output_root
        / "manifests"
        / f"run_manifest_yr{config.year}_q{config.quarter}.json"
    )
    manifest_path.parent.mkdir(parents=True, exist_ok=True)
    manifest_path.write_text(json.dumps(manifest, indent=2, sort_keys=True) + "\n")
    return manifest_path


def run(config: RunConfig) -> None:
    """Run the full v4 split-grain dominant NAICS build."""

    start = time.time()
    issue_log_path = quality_issue_log_path(config)
    issue_log_path.parent.mkdir(parents=True, exist_ok=True)
    with issue_log_path.open("a", encoding="utf-8") as log_file:
        log_file.write(
            json.dumps(
                {
                    "event": "quarter_start",
                    "year": config.year,
                    "qtr": config.quarter,
                    "source_path": str(config.source_path),
                    "action_for_duplicate_naics_run_key": "kept_first_row",
                },
                sort_keys=True,
            )
            + "\n"
        )
    print(
        f"domnaics_v4 start year={config.year} quarter={config.quarter} "
        f"source={config.source_path} output_root={config.output_root}"
    )
    state_fips, cache_stats = cache_normalized_ldb(config)
    print(f"states_to_process={state_fips}")
    clear_existing_quarter_outputs(config, state_fips)

    state_summaries = []
    for fips in state_fips:
        state_summaries.append(process_state(config, fips))

    manifest_path = write_manifest(config, state_summaries)
    if not config.keep_cache:
        shutil.rmtree(config.cache_dir.parent, ignore_errors=True)
    elapsed_minutes = (time.time() - start) / 60
    total_input_rows = sum(stats["input_rows"] for stats in cache_stats.values())
    print(
        f"domnaics_v4 complete states={len(state_fips)} "
        f"input_rows={total_input_rows} manifest={manifest_path} "
        f"quality_issue_log={issue_log_path} elapsed_minutes={elapsed_minutes:.2f}"
    )


def main(argv: Optional[Sequence[str]] = None) -> None:
    """CLI wrapper for the v4 dominant NAICS build."""

    run(parse_args(argv))


if __name__ == "__main__":
    main()


