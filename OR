
def threaded_hojo(pool,years,quarters,cohort,max_workers=8):
    tasks=[(y,q) for y in years for q in quarters]

    def run_task(t):
        y,q=t
        return get_hojo_records(pool,y,q,cohort)

    with ThreadPoolExecutor(max_workers=max_workers) as ex:
        dfs=list(ex.map(run_task,tasks))

    return pd.concat(dfs,ignore_index=True)

