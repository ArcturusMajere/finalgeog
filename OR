import pandas as pd
import plotly.graph_objects as go
import ipywidgets as widgets
from IPython.display import display

def interactive_heatmap(df):
    data=df.copy()
    if 'yr_qtr' not in data.columns:
        if {'yr','qtr'}.issubset(data.columns):
            data['yr_qtr']=data['yr'].astype(str)+'-'+data['qtr'].astype(str)
        else:
            raise ValueError("df must contain 'yr_qtr' or both 'yr' and 'qtr'")
    data['yr_qtr']=data['yr_qtr'].astype(str)
    data['sector']=data['sector'].astype(str)
    metric_options=[c for c in ['counts','mean_wage','median_wage','percentile75','percentile25'] if c in data.columns]
    if not metric_options:
        raise ValueError("No valid metric columns found")
    qtr_order=sorted(data['yr_qtr'].unique(),key=lambda x:(int(str(x).split('-')[0]),int(str(x).split('-')[1])))
    has_state='state' in data.columns
    if has_state:
        data['state']=data['state'].astype(str)
        state_options=sorted(data['state'].unique())

    def draw(metric,state=None):
        d=data.copy()
        if has_state and state is not None:
            d=d[d['state']==str(state)]
        heat=d.pivot_table(index='sector',columns='yr_qtr',values=metric,aggfunc='mean')
        heat=heat.reindex(columns=qtr_order)
        if 'counts' in d.columns:
            cnt=d.pivot_table(index='sector',columns='yr_qtr',values='counts',aggfunc='sum')
            cnt=cnt.reindex(index=heat.index,columns=heat.columns)
            customdata=cnt.to_numpy()
            hovertemplate=f"sector=%{{y}}<br>yr_qtr=%{{x}}<br>{metric}=%{{z:,.2f}}<br>counts=%{{customdata:,.0f}}<extra></extra>"
        else:
            customdata=None
            hovertemplate=f"sector=%{{y}}<br>yr_qtr=%{{x}}<br>{metric}=%{{z:,.2f}}<extra></extra>"
        fig=go.Figure(go.Heatmap(z=heat.to_numpy(),x=heat.columns.tolist(),y=heat.index.tolist(),customdata=customdata,colorscale='Viridis',hovertemplate=hovertemplate))
        title=f"{metric} by sector and quarter"
        if has_state and state is not None:
            title=f"{title} | state {state}"
        fig.update_layout(title=title,xaxis_title='yr_qtr',yaxis_title='sector',height=max(500,30*len(heat.index)))
        fig.show()

    if has_state:
        widgets.interact(draw,metric=widgets.Dropdown(options=metric_options,value=metric_options[0],description='metric'),state=widgets.Dropdown(options=state_options,value=state_options[0],description='state'))
    else:
        widgets.interact(draw,metric=widgets.Dropdown(options=metric_options,value=metric_options[0],description='metric'))
