# provides function execution time decor
def timer(f):
    def wrapper(*args, **kwargs):
        st = time.time();result=f(*args, **kwargs)
        et = time.time();T = (et-st)/60
        print(f"wow fast!: {T:.8f} min")
        return result
    return(wrapper)

# converts fips to a state name
def fips2name(state_code):
    try:return us.states.lookup(state_code.zfill(2)).name
