    border-right: 1px solid var(--border);
    position: sticky;
    left: 0;
    z-index: 3;
  }}
  thead .row-idx {{ z-index: 4; }}

  /* Column header heat classes */
  .col-cool     {{ background: var(--col-cool); color: var(--col-cool-text); }}
  .col-warm-low {{ background: var(--col-wl);   color: var(--col-wl-text); }}
  .col-warm-mid {{ background: var(--col-wm);   color: var(--col-wm-text); }}
  .col-warm-high{{ background: var(--col-wh);   color: var(--col-wh-text); }}
  .col-rate {{
    display: block;
    font-size: 0.65rem;
    opacity: 0.7;
    font-weight: 400;
  }}

  /* Cell classes */
  td {{ padding: 6px 12px; border: 1px solid var(--border); vertical-align: middle; }}
  tbody tr:hover td {{ filter: brightness(1.25); }}

  .match        {{ background: var(--match); color: var(--match-text); }}
  .mismatch-low {{ background: var(--low);   color: var(--low-text); }}
  .mismatch-mid {{ background: var(--mid);   color: var(--mid-text); }}
  .mismatch-high{{ background: var(--high);  color: var(--high-text); }}

  .v1 {{ display: block; }}
  .v2 {{ display: block; opacity: 0.65; font-size: 0.7rem; }}

  /* ── Footer ── */
  .footer {{
    margin-top: 2rem;
    font-size: 0.75rem;
    color: var(--muted);
    font-family: 'JetBrains Mono', monospace;
    text-align: center;
