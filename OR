import os
import sys
import time
import functools
import threading
import tracemalloc
from dataclasses import dataclass, asdict

try:
    import psutil
except ImportError:
    psutil = None

@dataclass
class UsageReport:
    name: str
    ok: bool
    wall_seconds: float
    cpu_seconds: float
    rss_start_mb: float | None
    rss_end_mb: float | None
    rss_peak_mb: float | None
    rss_delta_mb: float | None
    tracemalloc_current_mb: float
    tracemalloc_peak_mb: float
    thread_count_start: int
    thread_count_end: int
    thread_count_peak: int
    frame_count_start: int
    frame_count_end: int
    frame_count_peak: int
    max_stack_depth_start: int
    max_stack_depth_end: int
    max_stack_depth_peak: int
    exception_type: str | None

def _mb(x):
    return None if x is None else x / 1024 / 1024

def _process():
    return psutil.Process(os.getpid()) if psutil else None

def _rss_mb(proc=None):
    if proc is None:
        proc = _process()
    if proc is None:
        return None
    try:
        return _mb(proc.memory_info().rss)
    except Exception:
        return None

def _frame_stats():
    frames = sys._current_frames()
    depths = []
    for frame in frames.values():
        n = 0
        while frame is not None:
            n += 1
            frame = frame.f_back
        depths.append(n)
    return len(frames), max(depths, default=0)

def _plot_usage(samples, title):
    try:
        import matplotlib.pyplot as plt
    except ImportError:
        print("matplotlib is not installed; skipping plots")
        return
    if not samples:
        return
    t = [s["t"] for s in samples]
    rss = [s["rss_mb"] for s in samples]
    pycur = [s["py_current_mb"] for s in samples]
    pypeak = [s["py_peak_mb"] for s in samples]
    threads = [s["threads"] for s in samples]
    frames = [s["frames"] for s in samples]
    depth = [s["max_stack_depth"] for s in samples]

    if any(v is not None for v in rss):
        plt.figure()
        plt.plot(t, rss)
        plt.xlabel("Seconds")
        plt.ylabel("RSS memory MB")
        plt.title(f"{title}: process memory")
        plt.grid(True)
        plt.show()

    plt.figure()
    plt.plot(t, pycur, label="Current")
    plt.plot(t, pypeak, label="Peak")
    plt.xlabel("Seconds")
    plt.ylabel("Python allocation MB")
    plt.title(f"{title}: tracemalloc")
    plt.legend()
    plt.grid(True)
    plt.show()

    plt.figure()
    plt.plot(t, threads)
    plt.xlabel("Seconds")
    plt.ylabel("Thread count")
    plt.title(f"{title}: threads")
    plt.grid(True)
    plt.show()

    plt.figure()
    plt.plot(t, frames)
    plt.xlabel("Seconds")
    plt.ylabel("Live frame count")
    plt.title(f"{title}: frames")
    plt.grid(True)
    plt.show()

    plt.figure()
    plt.plot(t, depth)
    plt.xlabel("Seconds")
    plt.ylabel("Max stack depth")
    plt.title(f"{title}: stack depth")
    plt.grid(True)
    plt.show()

def monitor_usage(print_report=True, return_report=False, plot=True, sample_interval=0.25, label=None, raise_errors=True):
    def decorate(fn):
        @functools.wraps(fn)
        def wrapped(*args, **kwargs):
            proc = _process()
            name = label or fn.__name__
            samples = []
            stop_event = threading.Event()
            thread_count_start = threading.active_count()
            frame_count_start, max_stack_depth_start = _frame_stats()
            rss_start_mb = _rss_mb(proc)
            started_tracemalloc = not tracemalloc.is_tracing()
            if started_tracemalloc:
                tracemalloc.start()
            tracemalloc.reset_peak()

            def sample_loop():
                start = time.perf_counter()
                while not stop_event.is_set():
                    current, peak = tracemalloc.get_traced_memory()
                    frame_count, max_stack_depth = _frame_stats()
                    samples.append({
                        "t": time.perf_counter() - start,
                        "rss_mb": _rss_mb(proc),
                        "py_current_mb": _mb(current),
                        "py_peak_mb": _mb(peak),
                        "threads": threading.active_count(),
                        "frames": frame_count,
                        "max_stack_depth": max_stack_depth
                    })
                    stop_event.wait(sample_interval)

            sampler = threading.Thread(target=sample_loop, daemon=True)
            sampler.start()
            cpu_start = time.process_time()
            wall_start = time.perf_counter()
            ok = True
            exc_type = None
            result = None

            try:
                result = fn(*args, **kwargs)
            except Exception as e:
                ok = False
                exc_type = type(e).__name__
                if not raise_errors:
                    result = e
                else:
                    raise
            finally:
                wall_seconds = time.perf_counter() - wall_start
                cpu_seconds = time.process_time() - cpu_start
                stop_event.set()
                sampler.join(timeout=max(sample_interval * 2, 1))
                current, peak = tracemalloc.get_traced_memory()
                frame_count_end, max_stack_depth_end = _frame_stats()
                rss_end_mb = _rss_mb(proc)
                thread_count_end = threading.active_count()
                if not samples:
                    samples.append({
                        "t": wall_seconds,
                        "rss_mb": rss_end_mb,
                        "py_current_mb": _mb(current),
                        "py_peak_mb": _mb(peak),
                        "threads": thread_count_end,
                        "frames": frame_count_end,
                        "max_stack_depth": max_stack_depth_end
                    })
                rss_vals = [s["rss_mb"] for s in samples if s["rss_mb"] is not None]
                thread_vals = [s["threads"] for s in samples]
                frame_vals = [s["frames"] for s in samples]
                depth_vals = [s["max_stack_depth"] for s in samples]
                report = UsageReport(
                    name=name,
                    ok=ok,
                    wall_seconds=wall_seconds,
                    cpu_seconds=cpu_seconds,
                    rss_start_mb=rss_start_mb,
                    rss_end_mb=rss_end_mb,
                    rss_peak_mb=max(rss_vals) if rss_vals else None,
                    rss_delta_mb=None if rss_start_mb is None or rss_end_mb is None else rss_end_mb - rss_start_mb,
                    tracemalloc_current_mb=_mb(current),
                    tracemalloc_peak_mb=_mb(peak),
                    thread_count_start=thread_count_start,
                    thread_count_end=thread_count_end,
                    thread_count_peak=max(thread_vals, default=thread_count_end),
                    frame_count_start=frame_count_start,
                    frame_count_end=frame_count_end,
                    frame_count_peak=max(frame_vals, default=frame_count_end),
                    max_stack_depth_start=max_stack_depth_start,
                    max_stack_depth_end=max_stack_depth_end,
                    max_stack_depth_peak=max(depth_vals, default=max_stack_depth_end),
                    exception_type=exc_type
                )
                wrapped.last_usage_report = report
                wrapped.last_usage_samples = samples

                if print_report:
                    d = asdict(report)
                    width = max(map(len, d))
                    print("\nusage report")
                    print("-" * 48)
                    for k, v in d.items():
                        if isinstance(v, float):
                            print(f"{k:<{width}} : {v:,.4f}")
                        else:
                            print(f"{k:<{width}} : {v}")
                    print("-" * 48)

                if plot:
                    _plot_usage(samples, name)

                if started_tracemalloc:
                    tracemalloc.stop()

            if return_report:
                return result, wrapped.last_usage_report
            return result

        wrapped.last_usage_report = None
        wrapped.last_usage_samples = None
        return wrapped
    return decorate
