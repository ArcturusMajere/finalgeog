import pandas as pd
from sqlalchemy import text, bindparam

def query_oracle_ids_by_period(
    engine,
    ids,
    yr,
    qtr,
    fips,
    table_name,
    id_col="id",
    yr_col="yr",
    qtr_col="qtr",
    fips_col="fips",
    batch_size=900,
    columns="*"
):
    ids = [str(x) for x in ids if x is not None]
    ids = list(dict.fromkeys(ids))

    if not ids:
        return pd.DataFrame()

    dfs = []

    sql = text(f"""
        SELECT {columns}
        FROM {table_name}
        WHERE {id_col} IN :ids
          AND {yr_col} = :yr
          AND {qtr_col} = :qtr
          AND {fips_col} = :fips
    """).bindparams(bindparam("ids", expanding=True))

    with engine.connect() as conn:
        for i in range(0, len(ids), batch_size):
            batch = ids[i:i + batch_size]
            df = pd.read_sql(
                sql,
                conn,
                params={
                    "ids": batch,
                    "yr": yr,
                    "qtr": qtr,
                    "fips": fips
                }
            )
            dfs.append(df)

    if not dfs:
        return pd.DataFrame()

    return pd.concat(dfs, ignore_index=True)



