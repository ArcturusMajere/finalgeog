# convert any naics to description..  
def naics_lookup(naics_code):
    if naics_code is None:
        return "00:Unknown"
    try:
        naics_code = str(int(naics_code))
    except ValueError:
        return np.nan
    sub_codes = [naics_code[:i] for i in range(2, len(naics_code) + 1)]
    titles = naics.loc[naics['Code'].isin(sub_codes), ['Code', 'Title']].drop_duplicates()
    if not titles.empty:
        most_specific = titles.iloc[-1]
        return f"{most_specific['Code']}: {most_specific['Title']}"
    return np.nan

