def add_group_column(df, lookup_df):
    if 'ID' not in df.columns:
        raise ValueError("df must contain 'ID'")
    if not {'ID','group'}.issubset(lookup_df.columns):
        raise ValueError("lookup_df must contain 'ID' and 'group'")
    df = df.copy()
    lookup_df = lookup_df.copy()
    df['ID'] = df['ID'].astype(str)
    lookup_df['ID'] = lookup_df['ID'].astype(str)
    mapper = lookup_df.drop_duplicates('ID').set_index('ID')['group']
    df['group'] = df['ID'].map(mapper)
    return df


