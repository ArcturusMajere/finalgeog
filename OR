def combine_categories6(df):
    cat=df[['category_1','category_2','category_3','category_4','category_5','category_6']].stack().reset_index(level=1,drop=True)
    df_long=df.drop(columns=['category_1','category_2','category_3','category_4','category_5','category_6']).join(cat.rename('CAT'))
    return df_long.reset_index(drop=True)

