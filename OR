%macro fetch_wage(fips=,yr=,qtr=,out=work.wage_data);

filename usr "USER.txt";
filename pwd "password.txt";

data _null_;
length user password $200;
infile usr truncover;
input user $200.;
call symputx('oracle_user',strip(user));
infile pwd truncover;
input password $200.;
call symputx('oracle_password',strip(password));
run;

proc sql;
connect to oracle
(
user="&oracle_user"
password="&oracle_password"
path="cfdbprd05.psb.bls.gov/wgrecprd.psb.bls.gov"
);

create table &out as
select *
from connection to oracle
(
select
t.BLS_ID,
t.UI,
t.RUN,
t.WAGE,
t.YR,
t.QTR,
t.state_code
from wagerecusr.wage_data t
where t.YR = &yr
and t.QTR = &qtr
and t.state_code = '&fips'
);

disconnect from oracle;
quit;

proc sql noprint;
select count(*) into :row_count trimmed
from &out;
quit;

%put rows=&row_count;

%mend;
