import os,psutil,gc
_last=None
def checkmem(label=''):
    global _last
    gc.collect()
    p=psutil.Process(os.getpid())
    rss=p.memory_info().rss/1024/1024
    pct=p.memory_percent()
    delta='' if _last is None else f', delta {rss-_last:+.2f} MB'
    print(f'{label} RSS {rss:.2f} MB, process pct {pct:.2f}%{delta}')
    _last=rss
