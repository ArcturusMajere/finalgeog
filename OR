
import pandas as pd
from sqlalchemy import text

def bls_id_qtr_continuity_summary(engine,state_code):
    query=text("""
        WITH base AS (
            SELECT
                bls_id,
                state_code,
                yr,
                qtr,
                wage,
                (yr * 4 + qtr) AS qidx
            FROM wagerecusr.wage_data
            WHERE state_code = :state_code
              AND bls_id IS NOT NULL
              AND (yr * 4 + qtr) BETWEEN (2020 * 4 + 1) AND (2025 * 4 + 4)
        ),
        qtr_ids AS (
            SELECT DISTINCT
                bls_id,
                yr,
                qtr,
                qidx
            FROM base
        ),
        eligible_ids AS (
            SELECT
                q.bls_id,
                q.yr,
                q.qtr,
                q.qidx
            FROM qtr_ids q
            WHERE q.qidx BETWEEN (2020 * 4 + 3) AND (2025 * 4 + 3)
              AND EXISTS (
                SELECT 1 FROM qtr_ids p
                WHERE p.bls_id = q.bls_id
                  AND p.qidx = q.qidx - 2
            )
              AND EXISTS (
                SELECT 1 FROM qtr_ids p
                WHERE p.bls_id = q.bls_id
                  AND p.qidx = q.qidx - 1
            )
              AND EXISTS (
                SELECT 1 FROM qtr_ids p
                WHERE p.bls_id = q.bls_id
                  AND p.qidx = q.qidx + 1
            )
        ),
        all_counts AS (
            SELECT
                yr,
                qtr,
                qidx,
                COUNT(DISTINCT bls_id) AS total_ids_in_qtr
            FROM qtr_ids
            WHERE qidx BETWEEN (2020 * 4 + 3) AND (2025 * 4 + 3)
            GROUP BY yr,qtr,qidx
        ),
        eligible_wages AS (
            SELECT
                b.yr,
                b.qtr,
                b.qidx,
                b.bls_id,
                AVG(b.wage) AS id_mean_wage
            FROM base b
            JOIN eligible_ids e
              ON b.bls_id = e.bls_id
             AND b.qidx = e.qidx
            WHERE b.wage IS NOT NULL
            GROUP BY b.yr,b.qtr,b.qidx,b.bls_id
        ),
        eligible_summary AS (
            SELECT
                yr,
                qtr,
                qidx,
                COUNT(DISTINCT bls_id) AS eligible_ids,
                AVG(id_mean_wage) AS mean_wage_eligible_ids
            FROM eligible_wages
            GROUP BY yr,qtr,qidx
        )
        SELECT
            a.yr,
            a.qtr,
            a.total_ids_in_qtr,
            COALESCE(e.eligible_ids,0) AS eligible_ids,
            e.mean_wage_eligible_ids,
            ROUND(
                100.0 * COALESCE(e.eligible_ids,0) / NULLIF(a.total_ids_in_qtr,0),
                4
            ) AS eligible_pct
        FROM all_counts a
        LEFT JOIN eligible_summary e
          ON a.yr = e.yr
         AND a.qtr = e.qtr
         AND a.qidx = e.qidx
        ORDER BY a.yr,a.qtr
    """)
    df=pd.read_sql(query,engine,params={"state_code":state_code})
    df.columns=df.columns.str.lower()
    return df


