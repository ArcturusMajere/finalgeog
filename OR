from concurrent.futures import ThreadPoolExecutor
import pandas as pd

def threaded_hojo(user,password,dsn,years,quarters,cohort,threads=6):

    tasks=[(y,q) for y in years for q in quarters]

    def worker(t):
        y,q=t
        return get_hojo_records(user,password,dsn,y,q,cohort)

    with ThreadPoolExecutor(max_workers=threads) as ex:
        dfs=list(ex.map(worker,tasks))

    return pd.concat(dfs,ignore_index=True)

