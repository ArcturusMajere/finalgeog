</style>
</head>
<body>

<div class="header">
  <h1>DataFrame Comparison</h1>
  <div class="subtitle">{df1_name} &nbsp;vs&nbsp; {df2_name}</div>
</div>

<div class="stats">
  <div class="stat stat-total">
    <div class="stat-val">{total_cells}</div>
    <div class="stat-label">Total cells</div>
  </div>
  <div class="stat stat-match">
    <div class="stat-val">{match_count}</div>
    <div class="stat-label">Matches</div>
  </div>
  <div class="stat stat-miss">
    <div class="stat-val">{mismatch_count}</div>
    <div class="stat-label">Mismatches</div>
  </div>
  <div class="stat stat-rate">
    <div class="stat-val">{pct}%</div>
    <div class="stat-label">Disagreement</div>
  </div>
</div>

<div class="progress-wrap">
  <div class="progress-label">Agreement vs Disagreement</div>
  <div class="progress-bar">
    <div class="bar-match" style="width:{100 - float(pct):.1f}%"></div>
    <div class="bar-miss"  style="width:{pct}%"></div>
  </div>
</div>

{warnings_html}

<div class="legend">
  <div class="legend-item"><div class="legend-swatch s-match"></div>Match</div>
  <div class="legend-item"><div class="legend-swatch s-low"></div>Small diff (&lt;1)</div>
  <div class="legend-item"><div class="legend-swatch s-mid"></div>Medium diff (&lt;10)</div>
  <div class="legend-item"><div class="legend-swatch s-high"></div>Large diff / type mismatch</div>
  <span style="margin-left:auto">top = {df1_name} &nbsp;·&nbsp; bottom = {df2_name}</span>
</div>

<div class="table-wrap">
  <table>
    <thead><tr>{"".join(col_headers)}</tr></thead>
    <tbody>{"".join(table_rows)}</tbody>
  </table>
</div>

<div class="footer">
  Generated by compare_dataframes() &nbsp;·&nbsp; {n_rows} rows × {len(cols)} common columns
</div>

</body>
</html>"""

    tmp = tempfile.NamedTemporaryFile(
        mode="w", suffix=".html", delete=False,
        prefix="df_compare_", encoding="utf-8"
    )
    tmp.write(html)
    tmp.close()
    return tmp.name
