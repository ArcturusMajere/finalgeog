# aggregates to larger values possibly suitable for disclosure. 
def AGG_UP(df):
    out=df.copy()
    out["industry"]=out["naics4"].astype(str).eq("6244").map({True:"childcare",False:"other"})
    out["location"]=out["state"].astype(str).eq("California").map({True:"California",False:"found elsewhere"})
    result=out.groupby(["yr_qtr","original_class","class","location","industry"],as_index=False)["BLS_ID"].nunique().rename(columns={"BLS_ID":"id_count"})
    return out,result

# create new column: orginal wage class
def add_original_class(df):
    base = (df.loc[df["yr_qtr"].eq("2020-1"), ["BLS_ID", "class"]].rename(columns={"class": "original_class"}))
    return df.merge(base, on="BLS_ID", how="left")
