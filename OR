

def query_ui_wages(conn,ui_list,yr,qtr,fips,table_name="wagerecusr.wage_data"):
    if not ui_list:
        raise ValueError("ui_list cannot be empty")

    ui_binds={f"ui{i}":v for i,v in enumerate(ui_list)}
    ui_placeholders=",".join(f":ui{i}" for i in range(len(ui_list)))

    sql=f"""
        SELECT
            yr,
            qtr,
            state_code,
            COUNT(*) AS row_count,
            COUNT(DISTINCT id) AS id_count,
            AVG(wage) AS mean_wage
        FROM {table_name}
        WHERE ui IN ({ui_placeholders})
          AND yr = :yr
          AND qtr = :qtr
          AND state_code = :fips
        GROUP BY yr,qtr,state_code
    """

    params={
        **ui_binds,
        "yr":yr,
        "qtr":qtr,
        "fips":fips
    }

    df=pd.read_sql(sql,conn,params=params)
    df.columns=df.columns.str.lower()
    return df
