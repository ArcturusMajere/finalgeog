import pandas as pd
import oracledb
from concurrent.futures import ThreadPoolExecutor

def get_hojo_records(pool,yr,qtr,cohort):
    if not cohort:
        return pd.DataFrame()

    bind_vars=",".join([f":id{i}" for i in range(len(cohort))])

    sql=f"""
    SELECT *
    FROM HOJO
    WHERE yr=:yr
    AND qtr=:qtr
    AND WAGE>0
    AND FUND_ID IN ({bind_vars})
    """

    binds={"yr":yr,"qtr":qtr}
    binds.update({f"id{i}":v for i,v in enumerate(cohort)})

    with pool.acquire() as conn:
        with conn.cursor() as cur:
            cur.execute(sql,binds)
            cols=[c[0].upper() for c in cur.description]
            rows=cur.fetchall()

    return pd.DataFrame(rows,columns=cols)


def threaded_hojo(pool,years,quarters,cohort,max_workers=8):
    tasks=[(y,q) for y in years for q in quarters]

    def run_task(t):
        y,q=t
        return get_hojo_records(pool,y,q,cohort)

    with ThreadPoolExecutor(max_workers=max_workers) as ex:
        dfs=list(ex.map(run_task,tasks))

    return pd.concat(dfs,ignore_index=True)
