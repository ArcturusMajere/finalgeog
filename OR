
def extract_one(args):
    fips, yr, qtr = args
    df = Extract_QTR(fips, yr, qtr)
    return df
def extracthreaded(fipslist,
    start_year=2020,start_qtr=1,end_year=2025,end_qtr=3,max_workers=4):
    tasks = []
    for yr in range(start_year, end_year + 1):
        for qtr in range(1, 5):
            if yr == start_year and qtr < start_qtr:
                continue
            if yr == end_year and qtr > end_qtr:
                continue
            for fips in fipslist:
                tasks.append((fips, yr, qtr))
    out = []
    with ThreadPoolExecutor(max_workers=max_workers) as executor:
        futures = [executor.submit(extract_one, task) for task in tasks]
        for future in as_completed(futures):
            result = future.result()
            if result is not None:
                out.append(result)
    if not out:
        return pd.DataFrame()

    return pd.concat(out, ignore_index=True)
