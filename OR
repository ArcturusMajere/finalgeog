import pandas as pd
import plotly.graph_objects as go

def save_4_state_rolling_plot(data,metric="count",outfile="four_state_rolling_average.html"):
    if isinstance(data,str):
        df=pd.read_csv(data)
    else:
        df=data.copy()

    df.columns=df.columns.str.lower()
    df=df.sort_values(["state","yr","qtr"])

    if "period" not in df.columns:
        df["period"]=df["yr"].astype(str)+" Q"+df["qtr"].astype(str)

    if metric=="count":
        ycol="wage_7k_count_roll"
        rawcol="wage_7k_or_less_count"
        title="4-state rolling average count of wages <= $7,000 and not zero"
        ylabel="Rolling average count"
    elif metric=="pct":
        ycol="wage_7k_pct_roll"
        rawcol="wage_7k_or_less_pct"
        title="4-state rolling average percent of wages <= $7,000 and not zero"
        ylabel="Rolling average percent"
    else:
        raise ValueError("metric must be 'count' or 'pct'")

    if ycol not in df.columns:
        df[ycol]=df.groupby("state")[rawcol].transform(lambda x:x.rolling(4,min_periods=1).mean())

    fig=go.Figure()

    for state,g in df.groupby("state"):
        fig.add_trace(
            go.Scatter(
                x=g["period"],
                y=g[ycol],
                mode="lines+markers",
                name=state
            )
        )

    fig.update_layout(
        title=title,
        xaxis_title="Quarter",
        yaxis_title=ylabel,
        width=1300,
        height=700,
        legend_title="State"
    )

    fig.update_xaxes(tickangle=45)
    fig.write_html(outfile)
    return outfile


html_file=save_4_state_rolling_plot("wage_7k_dataset.csv",metric="count",outfile="four_state_count_rolling.html")
print(html_file)
