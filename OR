import pandas as pd

def combine_categories6(df):
    category_cols=[f'category_{i}' for i in range(1,7)]
    id_cols=[c for c in df.columns if c not in category_cols]
    out=df.melt(
        id_vars=id_cols,
        value_vars=category_cols,
        var_name='category_slot',
        value_name='CAT'
    )
    out=out.dropna(subset=['CAT'])
    out['CAT']=out['CAT'].astype(str).str.split(r'\s*[,;|]\s*')
    out=out.explode('CAT')
    out['CAT']=out['CAT'].str.strip()
    out=out[out['CAT'].ne('')]
    return out.reset_index(drop=True)
