import os
import psutil

def memory_mb():return psutil.Process(os.getpid()).memory_info().rss / 1024**2

def run_7k_cohort(engine, state_code, base_year, base_qtr):
    pairs = get_qtr_pairs(base_year, base_qtr)
    print(f"starting base {base_year} Q{base_qtr} | memory {memory_mb():.1f} MB")
    cohort = get7000(engine, state_code, base_year, base_qtr)
    print(f"base loaded | rows {len(cohort):,} | memory {memory_mb():.1f} MB")

    for i, (yr, qtr) in enumerate(pairs, start=1):
        print(f"step {i}/{len(pairs)} loading {yr} Q{qtr} | memory {memory_mb():.1f} MB")
        update = get7000(engine, state_code, yr, qtr)
        print(f"update loaded | rows {len(update):,} | memory {memory_mb():.1f} MB")
        before = len(cohort)
        cohort = update7k(cohort, update)
        after = len(cohort)
        dropped = before - after
        print(f"merged {yr} Q{qtr} | kept {after:,} | dropped {dropped:,} | memory {memory_mb():.1f} MB")
    print(f"done | final rows {len(cohort):,} | memory {memory_mb():.1f} MB")
    return cohort
