import pandas as pd
from sqlalchemy import text

def bls_7k_sum_summary_fast(engine,state_code):
    with engine.begin() as conn:
        conn.execute(text("""
            DROP TABLE IF EXISTS tmp_bls_qtr_wage
        """))

        conn.execute(text("""
            CREATE TEMP TABLE tmp_bls_qtr_wage AS
            SELECT
                bls_id,
                state_code,
                yr,
                qtr,
                (yr * 4 + qtr) AS qidx,
                SUM(wage) AS qtr_wage
            FROM wagerecusr.wage_data
            WHERE state_code = :state_code
              AND bls_id IS NOT NULL
              AND wage IS NOT NULL
              AND wage <> 0
              AND (yr * 4 + qtr) BETWEEN (2020 * 4 + 1) AND (2025 * 4 + 4)
            GROUP BY
                bls_id,
                state_code,
                yr,
                qtr,
                (yr * 4 + qtr)
        """),{"state_code":state_code})

        conn.execute(text("""
            ANALYZE tmp_bls_qtr_wage
        """))

        query=text("""
            WITH target_ids AS (
                SELECT
                    bls_id,
                    state_code,
                    yr,
                    qtr,
                    qidx
                FROM tmp_bls_qtr_wage
                WHERE qidx BETWEEN (2020 * 4 + 3) AND (2025 * 4 + 3)
            ),
            total_counts AS (
                SELECT
                    state_code,
                    yr,
                    qtr,
                    qidx,
                    COUNT(*) AS total_count
                FROM target_ids
                GROUP BY state_code,yr,qtr,qidx
            ),
            four_qtr_sums AS (
                SELECT
                    t.state_code,
                    t.yr,
                    t.qtr,
                    t.qidx,
                    t.bls_id,
                    SUM(b.qtr_wage) AS sum_wage_4qtr
                FROM target_ids t
                JOIN tmp_bls_qtr_wage b
                  ON b.bls_id = t.bls_id
                 AND b.state_code = t.state_code
                 AND b.qidx BETWEEN t.qidx - 2 AND t.qidx + 1
                GROUP BY
                    t.state_code,
                    t.yr,
                    t.qtr,
                    t.qidx,
                    t.bls_id
            ),
            sevenk_counts AS (
                SELECT
                    state_code,
                    yr,
                    qtr,
                    qidx,
                    COUNT(*) AS sevenk_or_less_count
                FROM four_qtr_sums
                WHERE sum_wage_4qtr <= 7000
                GROUP BY state_code,yr,qtr,qidx
            )
            SELECT
                t.state_code,
                t.yr,
                t.qtr,
                t.total_count,
                COALESCE(s.sevenk_or_less_count,0) AS sevenk_or_less_count,
                ROUND(
                    100.0 * COALESCE(s.sevenk_or_less_count,0) / NULLIF(t.total_count,0),
                    4
                ) AS sevenk_or_less_pct
            FROM total_counts t
            LEFT JOIN sevenk_counts s
              ON t.state_code = s.state_code
             AND t.yr = s.yr
             AND t.qtr = s.qtr
             AND t.qidx = s.qidx
            ORDER BY t.yr,t.qtr
        """)

        df=pd.read_sql(query,conn)

    df.columns=df.columns.str.lower()
    return df

df=bls_7k_sum_summary_fast(engine,"06")
print(df)
