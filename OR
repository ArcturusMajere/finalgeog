import pandas as pd
import plotly.graph_objects as go
import ipywidgets as widgets
from IPython.display import display

def wage_sector_state_heatmap(data,metrics=None,html_path=None):
    data['yr_qtr']=data['yr_qtr'].astype(str)
    data['sector']=data['sector'].astype(str)
    data['state']=data['state'].astype(str)
    if metrics is None:
        metrics=[c for c in ['counts','mean_wage','median_wage','percentile75','percentile25'] if c in data.columns]
    if not metrics:
        raise ValueError("No metric columns found.")
    for c in metrics:
        data[c]=pd.to_numeric(data[c],errors='coerce')
    yr_order=list(pd.unique(data['yr_qtr']))
    sector_order=list(pd.unique(data['sector']))
    state_order=sorted(data['state'].dropna().unique())
    state_dd=widgets.Dropdown(options=state_order,value=state_order[0],description='State:')
    metric_dd=widgets.Dropdown(options=metrics,value=metrics[0],description='Metric:')
    out=widgets.Output()
    def draw(state,metric):
        with out:
            out.clear_output(wait=True)
            d=data[data['state']==state]
            pivot=d.pivot_table(index='yr_qtr',columns='sector',values=metric,aggfunc='mean')
            pivot=pivot.reindex(index=yr_order,columns=sector_order)
            fig=go.Figure(data=go.Heatmap(
                z=pivot.values,
                x=pivot.columns,
                y=pivot.index,
                colorscale='Viridis',
                hovertemplate='state: '+state+'<br>sector: %{x}<br>yr_qtr: %{y}<br>'+metric+': %{z}<extra></extra>'
            ))
            fig.update_layout(
                title=f'{metric} heatmap by yr_qtr and sector for state {state}',
                xaxis_title='sector',
                yaxis_title='yr_qtr',
                height=max(500,35*len(yr_order)),
                margin=dict(l=120,r=80,t=90,b=120)
            )
            fig.update_xaxes(type='category')
            fig.update_yaxes(type='category',autorange='reversed')
            if html_path:
                fig.write_html(html_path)
            fig.show()
    widgets.interactive_output(draw,{'state':state_dd,'metric':metric_dd})
    display(widgets.HBox([state_dd,metric_dd]),out)
    draw(state_dd.value,metric_dd.value)

