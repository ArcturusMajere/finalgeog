def split_by_group(df, group_value):
    if 'group' not in df.columns:
        raise ValueError("df must contain 'group'")
    df = df.copy()
    group_value = str(group_value)
    df['group'] = df['group'].astype(str)
    df_group = df[df['group'] == group_value].copy()
    df_other = df[df['group'] != group_value].copy()
    return df_group, df_other

