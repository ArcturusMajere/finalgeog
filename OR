import pandas as pd

def aggregate_by_quarter_id(df):
    result=(
        df.groupby(["yr_qtr","ID"],as_index=False,dropna=False)
          .agg(
              wage_sum=("wage","sum"),
              hour_sum=("hours","sum")
          )
          .sort_values(["yr_qtr","ID"])
          .reset_index(drop=True)
    )
    return result

