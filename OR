"""Run domnaics_v4 historically or as a rolling update.

# Copy/paste usage:
# python3.12 "/wagerec/dalton/wage_records/Mikes Area/domnaics/run_domnaics_v4.py" --mode backfill --dry-run
# python3.12 "/wagerec/dalton/wage_records/Mikes Area/domnaics/run_domnaics_v4.py" --mode backfill
# python "Mikes Area/domnaics/run_domnaics_v4.py" --mode rolling --lookback-years 3 --dry-run
# python "Mikes Area/domnaics/run_domnaics_v4.py" --mode rolling --lookback-years 3
# Backfill mode is hard-bounded to source years >= 2006.
# Outputs are written as product/year=/qtr=/fips=/product.parquet partitions.
# Non-dry runs print one shared quality_issue_log path when finished.

# Dataflow:
# 1) discover_available_quarters()
# 2) load_inventory()
# 3) plan_quarters()
# 4) run selected year-quarters with domnaics_v4.run()
# 5) update inventory
"""

from __future__ import annotations

import argparse
import json
import re
import time
from datetime import datetime
from pathlib import Path
from typing import Optional, Sequence

from domnaics_v4 import (
    DEFAULT_LDB_ROOT,
    DEFAULT_OUTPUT_ROOT,
    DEFAULT_TMP_ROOT,
    OUTPUT_LAYOUT,
    RunConfig,
    run as run_quarter,
)


BACKFILL_START_YEAR = 2006
LDB_FILE_RE = re.compile(r"^estab_dynamic(?P<year>\d{4})(?P<quarter>[1-4])\.sas7bdat$")


def parse_args(argv: Optional[Sequence[str]] = None) -> argparse.Namespace:
    """Parse runner arguments."""

    parser = argparse.ArgumentParser(
        description="Backfill or rolling-update split-grain dominant NAICS outputs."
    )
    parser.add_argument("--mode", choices=("backfill", "rolling"), default="rolling")
    parser.add_argument("--lookback-years", type=int, default=3)
    parser.add_argument("--dry-run", action="store_true")
    return parser.parse_args(argv)


def discover_available_quarters(ldb_root: Path) -> list[tuple[int, int, Path, int, int]]:
    """Find available LDB SAS quarters under the source root."""

    quarters = []
    for path in sorted(ldb_root.glob("estab_dynamic*.sas7bdat")):
        match = LDB_FILE_RE.match(path.name)
        if match is None:
            continue
        stat = path.stat()
        quarters.append(
            (int(match.group("year")), int(match.group("quarter")), path, stat.st_size, stat.st_mtime_ns)
        )
    return sorted(quarters)


def load_inventory(output_root: Path) -> dict[str, object]:
    """Load the build inventory if present."""

    path = inventory_path(output_root)
    if not path.exists():
        return {"quarters": {}}
    return json.loads(path.read_text())


def inventory_path(output_root: Path) -> Path:
    """Return the v4 inventory path."""

    return output_root / "manifests" / "inventory.json"


def filter_quarters(
    quarters: list[tuple[int, int, Path, int, int]],
    mode: str,
) -> list[tuple[int, int, Path, int, int]]:
    """Apply the historical lower bound used by backfill mode."""

    if mode != "backfill":
        return quarters
    return [source for source in quarters if source[0] >= BACKFILL_START_YEAR]


def plan_quarters(
    quarters: list[tuple[int, int, Path, int, int]],
    inventory: dict[str, object],
    mode: str,
    lookback_years: int,
    current_year: int,
) -> list[tuple[tuple[int, int, Path, int, int], str, str]]:
    """Decide which available quarters should run."""

    built = inventory.get("quarters", {})
    cutoff_year = current_year - lookback_years
    plans = []
    for source in quarters:
        year, quarter, _, source_size, source_mtime_ns = source
        existing = built.get(f"{year}q{quarter}")
        changed = (
            not isinstance(existing, dict)
            or existing.get("source_size") != source_size
            or existing.get("source_mtime_ns") != source_mtime_ns
        )
        if existing is None:
            reason = "backfill" if mode == "backfill" else "missing_inventory"
            plans.append((source, "run", reason))
        elif changed:
            plans.append((source, "run", "source_changed"))
        elif mode == "backfill":
            plans.append((source, "skip", "already_built"))
        elif year >= cutoff_year:
            plans.append((source, "run", "rolling_window"))
        else:
            plans.append((source, "skip", "outside_rolling_window"))
    return plans


def update_inventory(
    inventory: dict[str, object],
    output_root: Path,
    source: tuple[int, int, Path, int, int],
    reason: str,
) -> None:
    """Record a successful quarter build in inventory."""

    year, quarter, source_path, source_size, source_mtime_ns = source
    inventory.setdefault("quarters", {})
    inventory["updated_at"] = time.strftime("%Y-%m-%d %H:%M:%S")
    inventory["output_root"] = str(output_root)
    inventory["quarters"][f"{year}q{quarter}"] = {
        "year": year,
        "quarter": quarter,
        "source_path": str(source_path),
        "source_size": source_size,
        "source_mtime_ns": source_mtime_ns,
        "manifest_path": str(
            output_root / "manifests" / f"run_manifest_yr{year}_q{quarter}.json"
        ),
        "fips": "all",
        "output_layout": OUTPUT_LAYOUT,
        "status": "built",
        "reason": reason,
        "built_at": time.strftime("%Y-%m-%d %H:%M:%S"),
    }


def write_inventory(output_root: Path, inventory: dict[str, object]) -> Path:
    """Write inventory metadata."""

    path = inventory_path(output_root)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(inventory, indent=2, sort_keys=True) + "\n")
    return path


def run(argv: Optional[Sequence[str]] = None) -> None:
    """Run historical backfill or rolling update orchestration."""

    args = parse_args(argv)
    inventory = load_inventory(DEFAULT_OUTPUT_ROOT)

    available = filter_quarters(
        discover_available_quarters(DEFAULT_LDB_ROOT),
        args.mode,
    )
    if not available:
        raise ValueError(f"No matching LDB source quarters found under {DEFAULT_LDB_ROOT}")

    plans = plan_quarters(
        available,
        inventory,
        mode=args.mode,
        lookback_years=args.lookback_years,
        current_year=datetime.now().year,
    )
    for source, action, reason in plans:
        year, quarter, source_path = source[:3]
        print(f"{action} {year}q{quarter} reason={reason} source={source_path}")
    if args.dry_run:
        return

    issue_log_path = (
        DEFAULT_OUTPUT_ROOT
        / "manifests"
        / f"quality_issues_{args.mode}_{time.strftime('%Y%m%d_%H%M%S')}.jsonl"
    )
    issue_log_path.parent.mkdir(parents=True, exist_ok=True)
    with issue_log_path.open("a", encoding="utf-8") as log_file:
        log_file.write(
            json.dumps(
                {
                    "event": "runner_start",
                    "mode": args.mode,
                    "action_for_duplicate_naics_run_key": "kept_first_row",
                },
                sort_keys=True,
            )
            + "\n"
        )

    for source, action, reason in plans:
        if action == "skip":
            continue
        year, quarter = source[:2]
        run_tag = f"yr{year}_q{quarter}_{time.strftime('%Y%m%d_%H%M%S')}"
        config = RunConfig(
            year=year,
            quarter=quarter,
            output_root=DEFAULT_OUTPUT_ROOT,
            tmp_root=DEFAULT_TMP_ROOT,
            fips=None,
            keep_cache=False,
            run_tag=run_tag,
            issue_log_path=issue_log_path,
        )
        run_quarter(config)
        update_inventory(inventory, DEFAULT_OUTPUT_ROOT, source, reason)
        path = write_inventory(DEFAULT_OUTPUT_ROOT, inventory)
        print(f"inventory_updated path={path} quarter={year}q{quarter}")
    print(f"quality_issue_log path={issue_log_path}")


def main() -> None:
    """CLI entrypoint."""

    run()


if __name__ == "__main__":
    main()
