            "original_class","original_state","original_sector","original_industry","original_yr_qtr"
        ])
    df["BLS_ID"] = df["BLS_ID"].astype(str)
    df["STATE_CODE"] = str(fips).zfill(2)
    df["state"] = us.states.lookup(fips).name if us.states.lookup(fips) else str(fips)
    df["sector"] = df["naics2"] if "naics2" in df.columns else pd.NA
    df["industry"] = df["naics4"] if "naics4" in df.columns else pd.NA
