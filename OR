# compiles childcare cohort per fips,yr,qtr
@timer
def fetch_childcare_cohort(fips,yr,qtr):
    w = fetch_wage(fips,yr,qtr)
    d = fetch_dom(fips,yr,qtr)
    w['UI'] = w['UI'].str.zfill(10);d['UI'] = d['UI'].str.zfill(10)
    df = pd.merge(w, d, how='left',on=['UI'], indicator=True)
    dff = dupeID(df)
    dff = dff[dff['WAGE'] > 0]
    cohort = dff[dff['naics4'] == '6244']
    print(f"{cohort.shape[0]} childcare peeps found in {us.states.lookup(fips)} in {yr}Q{qtr}")
    cohort['class'] = pd.cut(cohort['WAGE'], bins=[-float('inf'), 5609, 8964, 242634,float('inf')], labels=['low', 'middle', 'high','top 1%'])
    LOW = cohort[cohort['class'] == 'low']
    MID = cohort[cohort['class'] == 'middle']
    HIH = cohort[cohort['class'] == 'high']
    TOP = cohort[cohort['class'] == 'top 1%']
    l=LOW['BLS_ID'].to_list()
    m=MID['BLS_ID'].to_list()
    h=HIH['BLS_ID'].to_list()
    t=TOP['BLS_ID'].to_list()
    return(l,m,h,t)

    
# tracks cohort over yr,qtr
def find_cohort(yr, qtr, cohort):
    conn = oracledb.connect(user=open('USER.txt').read(),password=open('password.txt').read(),dsn="cfdbprd05.psb.bls.gov/wgrecprd.psb.bls.gov")
    chunk=1000
    dfs=[]
    for i in range(0,len(cohort),chunk):
        ids=cohort[i:i+chunk]
        bind_vars=",".join(f":id{j}" for j in range(len(ids)))
        sql=f"""
        SELECT *
        FROM wagerecusr.wage_data
        WHERE yr=:yr
        AND qtr=:qtr
        AND wage>0
        AND bls_id IN ({bind_vars})
        """
        binds={"yr":yr,"qtr":qtr}
        binds.update({f"id{j}":v for j,v in enumerate(ids)})
        with conn.cursor() as cur:
            cur.execute(sql,binds)
            cols=[c[0].upper() for c in cur.description]
            rows=cur.fetchall()

        dfs.append(pd.DataFrame(rows,columns=cols))
    df=pd.concat(dfs,ignore_index=True)
    df = dupeID(df)
    df['state'] = [fips2name(code) for code in df['STATE_CODE']]
    df['yr_qtr'] = f"{yr}-{qtr}"; df['YR'] = f"{yr}"; df['QTR'] = f"{qtr}"
    col= ['yr_qtr','state','BLS_ID','UI','WAGE','STATE_CODE','YR','QTR'];df = df[col]
    print(f"{df.shape[0]} cohort found in {yr} Q{qtr} ")
    return df
    
# threads find_cohort over range
def find_cohort_threader(years,quarters,cohort,threads=2):
    tasks=[(y,q) for y in years for q in quarters]
    def worker(t):
        y,q=t
        return find_cohort(y,q,cohort)
    with ThreadPoolExecutor(max_workers=threads) as ex:
        dfs=list(ex.map(worker,tasks))
    return pd.concat(dfs,ignore_index=True)

#track low,mid,high and combine
@timer
def track_bins(years,qtrs,l,m,h,max_threads=2):
    cohorts=[("low",l),("mid",m),("high",h)]
    dfs=[]
    for label,ids in cohorts:
        df=find_cohort_threader(years,qtrs,ids,max_threads)
        if not isinstance(df,pd.DataFrame):
            df=pd.DataFrame(df)
        df["class"]=label
        dfs.append(df)
    return pd.concat(dfs,ignore_index=True)

# query DOMNAICS for naics4 and assign industry
@timer
def dom4_join_fast(df):
    left=pl.from_pandas(df).select(["YR","QTR","STATE_CODE","UI"]).with_columns(
        pl.col("YR").cast(pl.Int64),pl.col("QTR").cast(pl.Int64),
        pl.col("STATE_CODE").cast(pl.Utf8),pl.col("UI").cast(pl.Utf8))
    right=(SCAN.select(["year","qtr","fips","ui_acct","naics4"]).with_columns(
            pl.col("year").cast(pl.Int64),pl.col("qtr").cast(pl.Int64),
            pl.col("fips").cast(pl.Utf8),pl.col("ui_acct").cast(pl.Utf8),pl.col("naics4").cast(pl.Utf8) )
            .rename({ "year":"YR","qtr":"QTR",
            "fips":"STATE_CODE","ui_acct":"UI"}).collect().unique(subset=["YR","QTR","STATE_CODE","UI"],keep="first"))
    out=(left.join(right,on=["YR","QTR","STATE_CODE","UI"],how="left").with_columns(pl.col("naics4").fill_null("0000")).to_pandas())
    df["naics4"]=out["naics4"].values
    df['industry'] = [naics_lookup(code) for code in df['naics4']]
    return df

