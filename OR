    df["original_class"] = pd.qcut(df["WAGE"], q=4, labels=CLASS_ORDER, duplicates="drop")
    df["original_state"] = df["state"]
    df["original_sector"] = df["sector"]
    df["original_industry"] = df["industry"]
    df["original_yr_qtr"] = df["yr_qtr"]
